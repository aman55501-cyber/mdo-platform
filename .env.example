# HDFC Securities
HDFC_API_KEY=your_hdfc_api_key
HDFC_API_SECRET=your_hdfc_api_secret
HDFC_REDIRECT_URL=http://localhost:8080/callback
HDFC_BASE_URL=https://developer.hdfcsec.com
HDFC_STATIC_IP=your.static.ip.address

# xAI Grok
GROK_API_KEY=your_xai_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Strategy
WATCHLIST=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK
RISK_PER_TRADE_PCT=2.0
MAX_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=5.0
TARGET_PCT=3.0
STOP_LOSS_PCT=1.5

# General
LOG_LEVEL=INFO
DB_PATH=vega_data.db
